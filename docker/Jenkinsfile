pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Build Docker Image') {
            steps {
                dir('docker') {
                    // Windows エージェントを想定
                    bat 'docker build -t hello:latest .'
                }
            }
        }
        stage('Run tests') {
            steps {
                // Windows エージェントを想定
                bat 'docker run --rm hello:latest'
            }
        }
        stage('Push (optional)') {
            when {
                expression { return false } // 必要ならtrueにしてregistryへpush
            }
            steps {
                // 例: docker login と docker push の処理を入れる
                bat 'echo pushing...'
            }
        }
    }
    post {
        success {
            script {
                def message = "ビルド成功：[ビルドURL](${env.BUILD_URL})"
                withCredentials([string(credentialsId: 'webhook_URL', variable: 'WEBHOOK_URL_SECRET')]) {
                    // Windows エージェントを想定し、batステップを使用
                    bat """
                        python send_teams_notification.py "${WEBHOOK_URL_SECRET}" "${message}"
                    """
                }
            }
        }
        failure {
            script {
                def message = "ビルド失敗：[ビルドURL](${env.BUILD_URL})"
                withCredentials([string(credentialsId: 'webhook_URL', variable: 'WEBHOOK_URL_SECRET')]) {
                    // Windows エージェントを想定し、batステップを使用
                    bat """
                        python send_teams_notification.py "${WEBHOOK_URL_SECRET}" "${message}"
                    """
                }
            }
        }
        always {
            // ビルド後にローカルイメージをクリーンアップするなど
            bat 'docker image prune -f'
        }
    }
}
